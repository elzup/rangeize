{
  "name": "rangeize",
  "version": "1.0.1",
  "description": "[1,2,3,4,5] => [1,5] Convert sequential numbers to ranges",
  "author": "elzup",
  "license": "MIT",
  "type": "module",
  "main": "lib/cjs/index.js",
  "module": "lib/esm/index.js",
  "types": "lib/types/index.d.ts",
  "exports": {
    ".": {
      "types": "./lib/types/index.d.ts",
      "import": "./lib/esm/index.js",
      "require": "./lib/cjs/index.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/elzup/rangeize.git"
  },
  "bugs": {
    "url": "https://github.com/elzup/rangeize/issues"
  },
  "homepage": "https://github.com/elzup/rangeize#readme",
  "keywords": [
    "array",
    "interval",
    "range",
    "span",
    "typescript"
  ],
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "prepare": "git config core.hooksPath .githooks || true",
    "clean": "rimraf lib",
    "build": "npm run clean && npm run build:cjs && npm run build:esm && npm run build:types",
    "build:cjs": "tsc --module commonjs --outDir lib/cjs && echo '{\"type\": \"commonjs\"}' > lib/cjs/package.json",
    "build:esm": "tsc --module esnext --outDir lib/esm --moduleResolution node --allowSyntheticDefaultImports",
    "build:types": "tsc --declaration --emitDeclarationOnly --outDir lib/types",
    "format": "biome format .",
    "format:fix": "biome format --write .",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:cov": "vitest run --coverage",
    "bench": "vitest bench --run",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "lib/"
  ],
  "sideEffects": false,
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@elzup/tsconfig": "1.1.0",
    "@types/node": "24.12.0",
    "@vitest/coverage-v8": "^4.0.15",
    "@vitest/ui": "^4.0.15",
    "oxlint": "^1.31.0",
    "rimraf": "^6.1.2",
    "typescript": "5.9.3",
    "vitest": "^4.0.15"
  }
}
